# Email provider: gmail | outlook
EMAIL_PROVIDER=
EMAIL_ACCOUNT=

# Gmail OAuth — download credentials JSON from Google Cloud Console
# Create OAuth 2.0 Client ID → Desktop application → download JSON
GMAIL_CREDENTIALS_FILE=
GMAIL_TOKEN_FILE=

# Outlook OAuth (Microsoft Graph)
OUTLOOK_CLIENT_ID=
OUTLOOK_TENANT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TOKEN_FILE=

# LLM provider: gemini | local
LLM_PROVIDER=

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=

# Local LLM (Ollama / LM Studio — OpenAI-compatible endpoint)
LOCAL_LLM_BASE_URL=
LOCAL_LLM_MODEL=
LOCAL_LLM_API_KEY=

# Batch settings
BATCH_SIZE=
# Optional namespace prefix for labels. Leave blank for flat labels like
# "finance", "important". Set to e.g. "Mail" for nested labels "Mail/finance".
LABEL_PREFIX=

# Classification reliability
MAX_CLASSIFY_RETRIES=
BODY_CHAR_LIMIT=
DROPPED_LOG_FILE=

# Keyword routing (optional — rule file shortcircuits LLM on match)
KEYWORD_ROUTES_FILE=

# SQLite cache
DB_FILE=

# Notifications (Telegram)
# Set NOTIFY_PROVIDER=telegram to enable daily summary push notifications.
# Leave blank or set to "none" to disable.
#
# Setup steps:
#   1. Message @BotFather on Telegram → /newbot → copy the token shown.
#   2. Start a chat with your new bot, then visit:
#        https://api.telegram.org/bot<TOKEN>/getUpdates
#      Find "chat" → "id" in the JSON — that is your TELEGRAM_CHAT_ID.
#   3. Fill in the two values below, then run: python main.py notify-test
#
NOTIFY_PROVIDER=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
